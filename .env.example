# Which LLM provider: openai | fake
ALEX_LLM=openai
# OpenAI, or any OpenAI-compatible server (used when ALEX_LLM=openai)
ALEX_OPENAI_API_KEY=
ALEX_OPENAI_MODEL=gpt-4o-mini
# point at a local server (llama.cpp, vLLM, LM Studio, ...); empty = api.openai.com
ALEX_OPENAI_BASE_URL=
# per-task routing: send easy jobs to a small local server; empty = default above
ALEX_SUMMARIZE_BASE_URL=
ALEX_SAME_TOPIC_BASE_URL=
ALEX_EXTRACT_BASE_URL=
ALEX_RELATE_BASE_URL=
# where ALL tasks go once the budget below is spent; empty = defer the queue instead
ALEX_FALLBACK_BASE_URL=
# Storage
ALEX_DB_PATH=../data/alexandria.db
# Cost telemetry: executions ledger (prices are hardcoded in telemetry.py)
ALEX_EXECUTIONS_DB_PATH=../data/executions.db
# llm spend ceilings in $; 0 = off (see ALEX_FALLBACK_BASE_URL for the over-budget path)
ALEX_BUDGET_DAILY_USD=0
ALEX_BUDGET_MONTHLY_USD=0
# Embeddings (NOT pluggable — model fixed; only the path/threshold are config)
ALEX_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
ALEX_SIMILAR_TOP_K=5
ALEX_SIMILAR_THRESHOLD=0.55
# How much each source pulls in: abstract | balanced | exhaustive
# (the web Add-panel slider overrides this per upload)
ALEX_EXTRACTION_ABSTRACTION=balanced
