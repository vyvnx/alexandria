# Which LLM provider: openai | ollama | fake
ALEX_LLM=openai
# OpenAI (used when ALEX_LLM=openai)
ALEX_OPENAI_API_KEY=
ALEX_OPENAI_MODEL=gpt-4o-mini
# Ollama (used when ALEX_LLM=ollama)
ALEX_OLLAMA_HOST=http://localhost:11434
ALEX_OLLAMA_MODEL=llama3.1
# Storage
ALEX_DB_PATH=../data/alexandria.db
# Embeddings (NOT pluggable — model fixed; only the path/threshold are config)
ALEX_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
ALEX_SIMILAR_TOP_K=5
ALEX_SIMILAR_THRESHOLD=0.55
